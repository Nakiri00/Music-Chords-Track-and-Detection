<?xml version="1.0" encoding="utf-8" ?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="130dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:padding="8dp"
    android:background="?attr/selectableItemBackground"
>

    <!-- Label posisi: "Posisi 1", "Posisi 2", dll. -->
    <TextView
        android:id="@+id/tv_position_label"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Posisi 1"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="?attr/colorPrimary"
        android:layout_marginBottom="6dp"
    />

    <!-- Diagram fretboard -->
    <com.example.musicchords.ChordView
        android:id="@+id/cv_position_diagram"
        android:layout_width="110dp"
        android:layout_height="130dp"
    />

    <!-- Fret string: "X 3 2 0 1 0" -->
    <TextView
        android:id="@+id/tv_position_frets"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="X 3 2 0 1 0"
        android:textSize="11sp"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:fontFamily="monospace"
        android:layout_marginTop="6dp"
    />

</LinearLayout>
